#!/usr/bin/env bash
# post-commit — git 提交后唤醒 agent(LOOP 支柱1)
# 安装:拷到 <repo>/.git/hooks/post-commit 并 chmod +x
#   (Windows 的 Git 也支持 bash hook)
#
# 铁律:hook 必须快。这里只 touch 唤醒信号然后立刻返回,
# 绝不在 hook 里跑 agent 长循环——那是 run-loop(由定时器消费)的事。

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
LOOP_DIR="$REPO_ROOT/.loop"

if [ -d "$LOOP_DIR" ]; then
  printf '{"ts":"%s","src":"commit","sha":"%s"}' \
    "$(date -u +%FT%TZ)" "$(git rev-parse --short HEAD)" \
    > "$LOOP_DIR/WAKE.flag"
fi
# 静默退出,绝不阻塞 git commit
exit 0
